POSTGRES_DB=todo-db
POSTGRES_PASSWORD=password
POSTGRES_USER=user

DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}-test
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

CACHE_TTL_SECONDS=3600
CACHE_TASKS_KEY=cache:tasks
CACHE_CATEGORIES_KEY=cache:categories

CORS_ALLOWED_ORIGINS=["http://localhost:3000"]